        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "format": "table",
          "query": "from(bucket: \"raw_bucket\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"raw_measurement\" and r._field == \"value\")\n  |> filter(fn: (r) => r.siteId =~ /^${site:regex}$/)\n  |> keep(columns: [\"assetId\"])\n  |> group()\n  |> distinct(column: \"assetId\")\n  |> count()",
          "refId": "A"
        }
      ],
      "title": "Reporting assets",
