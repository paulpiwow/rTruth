          "query": "from(bucket: \"raw_bucket\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"raw_measurement\" and r._field == \"value\")\n  |> filter(fn: (r) => r.siteId =~ /^${site:regex}$/)\n  |> map(fn: (r) => ({ _time: r._time, _value: r._value, series: r.siteId + \"/\" + r.assetId + \"/\" + r.tagName }))\n  |> group(columns: [\"series\"])\n  |> sort(columns: [\"_time\"])",
          "refId": "A"
        }
      ],
      "title": "Live values — $site",
      "type": "timeseries"
    },
    {
