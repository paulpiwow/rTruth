      "gridPos": { "h": 11, "w": 24, "x": 0, "y": 11 },
      "id": 3,
      "options": { "showHeader": true, "sortBy": [{ "displayName": "_time", "desc": true }] },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "format": "table",
          "query": "from(bucket: \"raw_bucket\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"raw_measurement\" and (r._field == \"value\" or r._field == \"quality\"))\n  |> filter(fn: (r) => r.siteId =~ /^${site:regex}$/)\n  |> pivot(rowKey: [\"_time\", \"siteId\", \"lineId\", \"assetId\", \"tagName\", \"unit\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> keep(columns: [\"_time\", \"siteId\", \"lineId\", \"assetId\", \"tagName\", \"value\", \"unit\", \"quality\"])\n  |> sort(columns: [\"_time\"], desc: true)\n  |> limit(n: 100)",
          "refId": "A"
        }
      ],
      "title": "Latest readings",
      "type": "table"
    }
