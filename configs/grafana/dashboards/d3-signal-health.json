        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "format": "table",
          "rawSql": "SELECT \"siteId\", \"assetId\", \"tagName\", max(time) AS last_seen, to_unixtime(now()) - to_unixtime(max(time)) AS \"secondsAgo\" FROM raw_measurement WHERE time > now() - interval '24 hours' GROUP BY \"siteId\", \"assetId\", \"tagName\" ORDER BY \"secondsAgo\" DESC",
          "refId": "A"
