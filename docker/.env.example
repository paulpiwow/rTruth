# Copy to .env and adjust. Read by `docker compose` on first boot.
#   cp .env.example .env

# --- InfluxDB initial setup (applied only on the first boot) ---
INFLUX_USER=admin
# Must be at least 8 characters or InfluxDB setup will fail.
INFLUX_PASSWORD=change-me-please
# Admin token shared by Telegraf, Grafana and the API. Use a long random string.
INFLUX_TOKEN=dev-rtruth-token-change-me
# Org and initial bucket are pinned in docker-compose.yml (rhobot / raw_bucket);
# kept here for reference / scripts.
INFLUX_ORG=rhobot
INFLUX_BUCKET=raw_bucket

# --- Host ports (informational; compose maps each to the same value) ---
# Mosquitto   1883
# InfluxDB    8086
# Grafana     3000   (login: admin / admin)
# rtruth-api  8090
