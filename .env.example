# Copy to .env, then `docker compose up -d`.
#   cp .env.example .env
# .env is gitignored — never commit real secrets.

# InfluxDB v2 runs with auth ON. This is the admin token created at first boot
# (DOCKER_INFLUXDB_INIT_ADMIN_TOKEN) and used by Telegraf and Grafana to read/
# write. It's a shared dev credential, not a per-user login. Any non-empty value
# works on a fresh volume; changing it later needs `docker compose down -v`.
INFLUX_TOKEN=dev-rtruth-token

# Reference values, pinned in configs/telegraf + configs/grafana.
INFLUX_ORG=rhobot
INFLUX_BUCKET=raw_bucket

# --- Host ports (change any that clash with other projects on your machine) ---
MQTT_PORT=1883
INFLUX_PORT=8087      # InfluxDB API + web UI (v2 UI: admin / admin12345)
GRAFANA_PORT=3003     # Grafana UI (login: admin / admin)
