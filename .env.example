# Copy to .env, then `docker compose up -d`.
#   cp .env.example .env
# .env is gitignored — never commit real secrets.

# InfluxDB 3 runs with --without-auth for local dev (see docker-compose.yml),
# so this token is NOT enforced. It is still handed to Telegraf and Grafana so
# the stack is ready to flip auth back on later. Any non-empty value works.
INFLUX_TOKEN=dev-rtruth-token

# Reference values, pinned in configs/telegraf + configs/grafana.
INFLUX_ORG=rhobot
INFLUX_BUCKET=raw_bucket

# Bucket for the skid simulator's live readings (Phase 5 tail / Phase 6 needs).
# Created by scripts/create-skid-bucket.sh. See docs/skid-bucket-contract.md.
SKID_BUCKET=skid_bucket

# --- Host ports (change any that clash with other projects on your machine) ---
MQTT_PORT=1883
INFLUX_PORT=8087      # InfluxDB API, exposed for the rPipes connector (no web UI in v3)
GRAFANA_PORT=3003     # Grafana UI (login: admin / admin)
